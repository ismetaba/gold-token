# ─── GOLD Token — environment variables ──────────────────────────────────────
# Copy to .env and fill in values as needed.
#
# For local dev (docker compose up):
#   - Postgres, NATS, Anvil credentials are hard-coded in docker-compose.yml
#   - Fill in DEPLOYER_PRIVATE_KEY and role addresses with Anvil test accounts
#   - All other vars below are for testnet/mainnet use
#
# Anvil default account 0 (deterministic, mnemonic: "test test test ... junk"):
#   Address: 0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
#   Key:     0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ── Local dev overrides (docker compose) ─────────────────────────────────────
# GOLD_ENV=local
# DATABASE_URL=postgres://gold:gold@localhost:5432/gold
# NATS_URL=nats://localhost:4222
# CHAIN_RPC_URL=http://localhost:8545
# CHAIN_ID=31337
# MINT_CONTROLLER_ADDR=   # set after: cd contracts && forge script script/Deploy.s.sol ...

# ── RPC endpoints ──────────────────────────────────────────────────────────────
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Block explorer ─────────────────────────────────────────────────────────────
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# ── Deployer key ───────────────────────────────────────────────────────────────
# SECURITY: Never commit real keys. Use SoftHSM2 or a hardware wallet for
# mainnet deployments (see CAPA-18 for the signing abstraction layer).
# For Sepolia testnet only: a plain hex private key is acceptable.
DEPLOYER_PRIVATE_KEY=0x...

# ── Role addresses ─────────────────────────────────────────────────────────────
# Treasury: DEFAULT_ADMIN_ROLE + TREASURY_ROLE + UPGRADER_ROLE on all contracts.
# On mainnet this MUST be a Gnosis Safe with a 3/5 multisig or better.
TREASURY_ADDRESS=0x...

# Address with PAUSER_ROLE on GoldToken.
PAUSER_ADDRESS=0x...

# Address with KYC_WRITER_ROLE on ComplianceRegistry.
KYC_WRITER_ADDRESS=0x...

# Address with COMPLIANCE_OFFICER_ROLE on ComplianceRegistry.
COMPLIANCE_OFFICER_ADDRESS=0x...

# MintController: proposer proposes, executor executes after 3/5 approval.
MINT_PROPOSER_ADDRESS=0x...
MINT_EXECUTOR_ADDRESS=0x...

# MintController: 3-of-5 approvers (can overlap with treasury/team EOAs on testnet).
APPROVER_1=0x...
APPROVER_2=0x...
APPROVER_3=0x...
APPROVER_4=0x...
APPROVER_5=0x...

# BurnController operator address.
BURN_OPERATOR_ADDRESS=0x...

# ReserveOracle: auditor who attests gold reserves.
AUDITOR_ADDRESS=0x...

# ── Upgrade script overrides (optional) ────────────────────────────────────────
# If set, these override the address registry (deployments/<chainId>.json).
# Leave blank to read from the registry automatically.
GOLD_TOKEN_PROXY=
COMPLIANCE_REGISTRY_PROXY=
MINT_CONTROLLER_PROXY=
BURN_CONTROLLER_PROXY=
