# ─────────────────────────────────────────────────────────────────────────────
# Gold Token — Staging environment secrets template
#
# Copy to .env.staging on the staging server, fill in all values.
# This file must NEVER be committed to the repository.
# On the VPS: chmod 600 /opt/gold-token/.env.staging
#
# GitHub Actions secrets required for deploy-staging.yml:
#   STAGING_HOST        — IP or hostname of the staging VPS
#   STAGING_SSH_KEY     — Private key for the deploy@ user (PEM format)
#   SLACK_WEBHOOK_URL   — Slack incoming webhook for deploy notifications
#
# GitHub Actions environment: staging
# Managed at: https://github.com/ismetaba/gold-token/settings/environments
# ─────────────────────────────────────────────────────────────────────────────

# ── Docker image tag ─────────────────────────────────────────────────────────
# Set by the deploy workflow automatically. Override here to pin a specific tag.
# IMAGE_TAG=sha-abc1234

# ── Staging URL (used for NEXT_PUBLIC_* env vars) ────────────────────────────
# Protocol + hostname, no trailing slash. e.g. http://staging.example.com
STAGING_BASE_URL=http://YOUR_VPS_IP_OR_DOMAIN

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=gold
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── Blockchain — Sepolia ─────────────────────────────────────────────────────
# Alchemy/Infura RPC endpoint for Sepolia
CHAIN_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Deployed contract addresses (from CAPA-63 testnet deployment)
GOLD_TOKEN_ADDR=0x349bdDC43cdba65F666F52ec23C1693FC510dB06
MINT_CONTROLLER_ADDR=0x8C7c3B0CF8f89E53E24714aEf1394731151240Dd
BURN_CONTROLLER_ADDR=0x96F5887418bA664f6992C1ebe5b6ba1ac7AC9Ae0
RESERVE_ORACLE_ADDR=0x8D79aD1AA9De94e83972389F151969190E87ED0b

# ── Price Oracle ──────────────────────────────────────────────────────────────
# GoldAPI.io API key — https://www.goldapi.io/
GOLD_PRICE_API_KEY=YOUR_GOLD_API_KEY

# ── KYC service ───────────────────────────────────────────────────────────────
KYC_ADMIN_SECRET=CHANGE_ME_kyc_admin_secret

# ── JWT key files ─────────────────────────────────────────────────────────────
# Paths to RSA PEM files on the staging server.
# Generate: openssl genrsa -out jwt_private_key.pem 4096
#           openssl rsa -in jwt_private_key.pem -pubout -out jwt_public_key.pem
# Place at /etc/gold-token/ and chmod 600.
JWT_PRIVATE_KEY_FILE=/etc/gold-token/jwt_private_key.pem
JWT_PUBLIC_KEY_FILE=/etc/gold-token/jwt_public_key.pem

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_admin_password

# Slack incoming webhook for Alertmanager notifications
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
